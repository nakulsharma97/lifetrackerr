# ═══════════════════════════════════════════════════════════
# LifeTracker — Environment Configuration
# ═══════════════════════════════════════════════════════════
# Copy this file to `.env` and fill in your values.
#   cp .env.example .env
#
# Then deploy:
#   docker compose up -d
# ═══════════════════════════════════════════════════════════

# ─── Database (MySQL) ─────────────────────────────────────
DATABASE_ROOT_PASSWORD=changeme     # MySQL root password
DATABASE_PASSWORD=changeme          # MySQL app user password
DATABASE_USERNAME=lifetracker       # MySQL app username
DATABASE_NAME=lifetracker           # MySQL database name

# ─── JWT Security ─────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
JWT_SECRET=
JWT_EXPIRATION_MS=86400000          # Optional, defaults to 24h

# ─── SMTP / Email (optional — for password reset) ────────
MAIL_HOST=smtp.resend.com           # e.g. smtp.resend.com, smtp.sendgrid.net
MAIL_PORT=587
MAIL_USERNAME=resend                # SMTP username
MAIL_PASSWORD=                      # SMTP password / API key
MAIL_FROM=noreply@lifetracker.app   # From address

# ─── App URL ──────────────────────────────────────────────
APP_BASE_URL=http://localhost        # Public URL of your app
