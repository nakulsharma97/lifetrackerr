# ─── LifeTracker Environment Variables ─────────────────────
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# Docker Compose automatically reads .env from the project root.
# Never commit .env to version control (it's in .gitignore).

# ─── Database ─────────────────────────────────────────────
# PostgreSQL password for the lifetracker user
# Generate a strong password:
#   node -e "console.log(require('crypto').randomBytes(24).toString('hex'))"
DB_PASSWORD=changeme

# ─── Security ─────────────────────────────────────────────
# JWT signing key — 256-bit (32 bytes) key encoded in Base64
# This MUST be changed for any production deployment.
# Generate a new one:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
JWT_SECRET=

# ─── SMTP / Email (optional — required for password reset) ─
# MAIL_HOST=smtp.resend.com
# MAIL_PORT=587
# MAIL_USERNAME=resend
# MAIL_PASSWORD=re_xxxxxxxxxxxx
# MAIL_FROM=noreply@yourdomain.com

# ─── Application ──────────────────────────────────────────
# Base URL of the running app (used in password reset emails)
# APP_BASE_URL=https://lifetracker.yourdomain.com

# Backend server port (default: 8080)
# PORT=8080
